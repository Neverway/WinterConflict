            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 0
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: 
            chatContent: '*The cabin has gone silent.'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 0
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: 
            chatContent: '*You hear slight bickering murmurs.'
