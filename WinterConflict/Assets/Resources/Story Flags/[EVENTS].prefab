                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 1
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: ???
            chatContent: '*"What if it''s Lynx?"'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 1
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: ???
            chatContent: '*"Why would they knock?"'
