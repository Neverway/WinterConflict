        overrideExistingEvents: 0
        textEvent:
          frames:
          - name: 
            chatContent: '*You walked up to the cabin.'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
