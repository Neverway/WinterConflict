        textEvent:
          frames:
          - name: 
            chatContent: '*You walked up to the cabin.'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 0
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: 
            chatContent: '*You can hear muffled voices inside.'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 0
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: ???
            chatContent: '*"-No, I wont..." (unintelligable)'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 0
            preventTextSkipping: 0
            preventTextContinuing: 0
            autoProgressOnComplete: 0
          - name: ???
            chatContent: '*"Well it''s not like we have much of a choice!"'
            portrait: {fileID: 0}
            chatterVoice: {fileID: 0}
            OnFrameStarted:
              m_PersistentCalls:
                m_Calls: []
            OnFrameCompleted:
              m_PersistentCalls:
                m_Calls: []
            displayMode: 0
